# ─── cloudseeding-collector environment ─────────────────────────────────────
# Copy to .env (or set these in Railway → Variables). All are optional; defaults
# work, but setting OpenSky credentials is strongly recommended.

# Where the SQLite DB lives (Railway: point at the mounted volume).
DB_PATH=/app/data/cloudseeding.db

# ── Flight data ──────────────────────────────────────────────────────────────
# OpenSky OAuth2 client credentials. WITHOUT these you get the anonymous endpoint,
# which is heavily rate-limited (the cause of the 429 / "fetch failed" cycles).
# Create an API client at https://opensky-network.org/ (account → API clients).
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=
# airplanes.live fallback (free, unfiltered). Set to 0 to disable.
USE_AIRPLANES_LIVE=1

# ── Observation source for anomaly detection ─────────────────────────────────
# "openmeteo" (default) = MODEL best-estimate (runnable now, but it is a forecast
#   model, not observation). "mrms"/"goes" = real radar/satellite via a sidecar.
OBSERVATION_SOURCE=openmeteo
# If using mrms/goes, the HTTP sidecar that serves parsed observations:
# OBSERVATION_SIDECAR_URL=http://localhost:8080

# ── Cadence ──────────────────────────────────────────────────────────────────
COLLECT_INTERVAL_MS=300000          # 5 min
MAINTENANCE_INTERVAL_MS=86400000    # 24 h (VACUUM + monitor + aggregate)
FORECAST_HORIZON_HOURS=12           # how far ahead to persist forecasts (the baseline)
RAW_RETENTION_HOURS=48              # full-resolution rolling window

# ── Analysis tuning (sensible defaults in config.js) ─────────────────────────
# SEED_ALT_MIN=5000
# SEED_ALT_MAX=14000
# CLOUD_EXCESS_VS_FORECAST=25
# PRECIP_EXCESS_VS_FORECAST=0.2
# UPWIND_RADIUS_KM=40
# PRESERVE_THRESHOLD=45

# ── Aggregate ("repeat offender") test ───────────────────────────────────────
# AGGREGATE_WINDOW_DAYS=90
# AGGREGATE_PERMUTATIONS=500
# AGGREGATE_MIN_ASSOC=3
# AGGREGATE_FDR_ALPHA=0.1

# ── API server ───────────────────────────────────────────────────────────────
PORT=4000
